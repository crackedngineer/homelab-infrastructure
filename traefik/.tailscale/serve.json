  "version": "0.0.1",
  "Services": {
    "svc:traefik": {
      "TCP": {
        "443": {
          "HTTPS": true
        },
        "80": {
          "HTTP": true
        }
      }
    }
  },
  "Web": {
    "alpine-traefik.tailcda03.ts.net:443": {
      "Handlers": {
